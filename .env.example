# ConjLean — API key template
# Copy this file to .env and fill in the keys you plan to use.
# Never commit .env to version control.
#
# Only the key for your chosen provider is required.
# Set provider: <name> in configs/config.yaml to activate it.

# Anthropic (provider: anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (provider: openai)
OPENAI_API_KEY=sk-...

# Google Gemini (provider: gemini)
GEMINI_API_KEY=AIza...

# HuggingFace Inference API (provider: huggingface)
# Also required to download gated models (e.g. Llama-3) via local_hf / vLLM
HF_TOKEN=hf_...
